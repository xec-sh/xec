{
  "name": "@xec-sh/cli",
  "description": "Xec: The Universal Shell for TypeScript",
  "version": "0.8.3",
  "author": "LuxQuant",
  "type": "module",
  "license": "MIT",
  "directories": {
    "bin": "./bin",
    "dist": "./dist"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "globals.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "cli",
    "shell",
    "typescript",
    "automation",
    "devops",
    "ssh",
    "docker",
    "kubernetes",
    "orchestration",
    "scripting"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "xec": "bin/xec"
  },
  "dependencies": {
    "@xec-sh/core": "workspace:*",
    "@xec-sh/kit": "workspace:*",
    "@xec-sh/loader": "workspace:*",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "fs-extra": "^11.3.3",
    "glob": "^13.0.0",
    "js-yaml": "^4.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/ssh2": "^1.15.5",
    "@xec-sh/testing": "workspace:*",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xec-sh/xec.git",
    "directory": "apps/xec"
  },
  "bugs": {
    "url": "https://github.com/xec-sh/xec/issues"
  },
  "homepage": "https://xec.sh"
}
