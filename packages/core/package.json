{
  "name": "@xec/core",
  "version": "0.3.1",
  "description": "DevOps orchestration and automation framework",
  "keywords": [
    "devops",
    "automation",
    "orchestration",
    "deployment",
    "infrastructure",
    "ssh",
    "docker",
    "typescript"
  ],
  "author": "DevGrid",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "prepublishOnly": "npm run build && npm run test",
    "docs": "typedoc src/index.ts --out docs/api"
  },
  "dependencies": {
    "@types/lodash-es": "^4.17.12",
    "@xec/ush": "workspace:*",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "async-hooks": "^1.0.0",
    "chalk": "^5.3.0",
    "glob": "^11.0.3",
    "globby": "^14.1.0",
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21",
    "node-fetch": "^3.3.2",
    "p-queue": "^8.1.0",
    "uuid": "^11.1.0",
    "which": "^5.0.0",
    "winston": "^3.11.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.14.202",
    "@types/node": "^24.0.13",
    "@types/uuid": "^10.0.0",
    "@types/which": "^3.0.4",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "typedoc": "^0.28.7",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "typescript": ">=4.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xec-sh/xec.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/xec-sh/xec/issues"
  },
  "homepage": "https://github.com/xec-sh/xec#readme"
}