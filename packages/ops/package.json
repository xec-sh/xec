{
  "name": "@xec-sh/ops",
  "version": "0.8.3",
  "description": "DevOps operations library — deploy, health checks, pipelines, discovery, workflows",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./deploy": {
      "types": "./dist/deploy/index.d.ts",
      "import": "./dist/deploy/index.js"
    },
    "./health": {
      "types": "./dist/health/index.d.ts",
      "import": "./dist/health/index.js"
    },
    "./pipeline": {
      "types": "./dist/pipeline/index.d.ts",
      "import": "./dist/pipeline/index.js"
    },
    "./workflow": {
      "types": "./dist/workflow/index.d.ts",
      "import": "./dist/workflow/index.js"
    },
    "./discovery": {
      "types": "./dist/discovery/index.d.ts",
      "import": "./dist/discovery/index.js"
    },
    "./retry": {
      "types": "./dist/retry/index.d.ts",
      "import": "./dist/retry/index.js"
    },
    "./completion": {
      "types": "./dist/completion/index.d.ts",
      "import": "./dist/completion/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xec-sh/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "devops",
    "deploy",
    "pipeline",
    "workflow",
    "health-check",
    "orchestration",
    "automation",
    "infrastructure",
    "ci-cd"
  ],
  "author": "LuxQuant",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xec-sh/xec.git",
    "directory": "packages/ops"
  }
}
