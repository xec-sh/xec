  "keywords": [
    "xec",
    "test",
    "utils",
    "docker",
    "kubernetes"
  ],
  "author": "LuxQuant",
  "license": "MIT",
  "dependencies": {
    "dockerode": "^4.0.9"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist",
    "docker",
    "docker-ssh-manager.sh"
  ]
}
